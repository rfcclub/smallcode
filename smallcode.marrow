// SmallCode — AI Coding Agent for Small LLMs
// Declared as a MarrowScript system with cognition layer
// Compiles to a complete agent runtime with bounded, deterministic LLM orchestration

system SmallCode {
  domain: cognitive_scaffold

  // ═══════════════════════════════════════════════════════════════════════════
  // ENTITIES
  // ═══════════════════════════════════════════════════════════════════════════

  entity Session {
    owns: [
      model_name: string,
      provider: string,
      context_budget: uint,
      turn_count: uint,
      status: string,
      working_memory: string
    ]
    constraints: [context_budget > 0, turn_count >= 0]
    states: active -> paused -> completed | abandoned
  }

  entity Turn {
    owns: [
      session_id: uuid,
      user_message: string,
      assistant_response: string,
      tool_calls: uint,
      tokens_used: uint,
      turn_number: uint
    ]
    constraints: [tool_calls >= 0, tokens_used >= 0]
    states: pending -> thinking -> tool_calling -> responding -> complete | failed
  }

  entity TaskPlan {
    owns: [
      session_id: uuid,
      description: string,
      total_steps: uint,
      completed_steps: uint,
      current_step: uint,
      steps_json: string
    ]
    constraints: [total_steps > 0, completed_steps <= total_steps, current_step <= total_steps]
    states: planning -> executing -> validating -> complete | failed
  }

  entity ToolCall {
    owns: [
      turn_id: uuid,
      tool_name: string,
      arguments_json: string,
      result: string,
      error: string,
      tokens_cost: uint,
      attempt: uint
    ]
    constraints: [attempt >= 1, attempt <= 3, tokens_cost >= 0]
    states: parsing -> validated -> executing -> complete | repair | failed
  }

  entity CodeFile {
    owns: [
      path: string,
      content: string,
      line_count: uint,
      summary: string,
      last_read_turn: uint
    ]
    constraints: [line_count >= 0]
  }

  entity WorkingMemory {
    owns: [
      session_id: uuid,
      content: string,
      token_count: uint,
      max_tokens: uint
    ]
    constraints: [token_count <= max_tokens, max_tokens > 0]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // MODELS — Optimized for small local LLMs
  // ═══════════════════════════════════════════════════════════════════════════

  model TinyRouter {
    provider: ollama
    name: "qwen2.5-coder:1.5b"
    context_window: 8192
    max_output: 128
    temperature: 0.0
    cost_class: tiny
    latency_class: fast
  }

  model SmallCoder {
    provider: ollama
    name: "qwen2.5-coder:7b"
    context_window: 32000
    max_output: 4096
    temperature: 0.1
    cost_class: small
    latency_class: medium
  }

  model MediumCoder {
    provider: ollama
    name: "qwen2.5-coder:14b"
    context_window: 32000
    max_output: 8192
    temperature: 0.1
    cost_class: medium
    latency_class: medium
  }

  model DevstralAgent {
    provider: ollama
    name: "devstral:latest"
    context_window: 32000
    max_output: 8192
    temperature: 0.1
    cost_class: medium
    latency_class: medium
  }

  model Qwen3Reasoner {
    provider: ollama
    name: "qwen3:8b"
    context_window: 32000
    max_output: 8192
    temperature: 0.1
    cost_class: small
    latency_class: medium
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // ROUTERS — Route based on task complexity
  // ═══════════════════════════════════════════════════════════════════════════

  // Main coding router: tiny handles classification, small handles simple edits,
  // medium handles complex multi-step tasks
  router coding_router {
    by: input.complexity
    tier trivial { max: 0.2 -> TinyRouter }
    tier simple  { max: 0.5 -> SmallCoder }
    tier complex {           -> MediumCoder }
    on_low_confidence: escalate
    confidence_threshold: 0.6
    fallback: MediumCoder
    observe: ["validation_pass_rate", "latency_p95_ms", "cost_usd_per_call"]
    policy: minimize_cost_subject_to {
      validation_pass_rate >= 0.85
    }
  }

  // Tool call router: tiny for classification, small for execution
  router tool_router {
    by: input.complexity
    tier classify { max: 0.3 -> TinyRouter }
    tier execute  {           -> SmallCoder }
    on_low_confidence: escalate
    confidence_threshold: 0.5
    fallback: SmallCoder
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // PROMPTS — Typed, validated, with repair
  // ═══════════════════════════════════════════════════════════════════════════

  // Stage 1: Classify what category of tool the model needs
  prompt classify_tool_category(user_message: string, context_summary: string) {
    model: TinyRouter
    template: "extension_point:tmpl_classify_category"
    returns: string
    timeout: 5s
    idempotent: true
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 200ms }
    cache: { key: hash(user_message), ttl: 5m }
    constraints: [
      output in ["read", "write", "search", "run", "plan", "web", "respond"]
    ]
  }

  // Main coding prompt — handles the actual task with bounded tool use
  // Phase 26: bounded refinement loop — generate → validate → fix → validate
  prompt coding_agent(task: string, context: string, tool_schemas: string, complexity: float) {
    router: coding_router
    template: "extension_point:tmpl_coding_agent"
    returns: string
    timeout: 120s
    validate: ast_compiles
    on_invalid: retry_with_repair_prompt
    retry: { max_attempts: 3, backoff: exponential, interval: 1s }
    tools: [tool_read_file, tool_patch, tool_search, tool_bash, tool_memory]
    stream: true
    loop: {
      steps: ["generate", "validate", "repair"]
      until: "validation_passes"
      max_iterations: 5
    }
  }

  // Task decomposition for complex requests
  prompt decompose_task(task_description: string, codebase_summary: string, complexity: float) {
    router: coding_router
    template: "extension_point:tmpl_decompose"
    returns: string
    timeout: 30s
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 500ms }
  }

  // Context compression when budget runs low
  prompt compress_conversation(history: string, max_tokens: uint) {
    model: SmallCoder
    template: "extension_point:tmpl_compress"
    returns: string
    timeout: 30s
    idempotent: true
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 500ms }
    constraints: [
      output.length <= max_tokens
    ]
  }

  // Tool call repair: when model produces malformed tool calls
  prompt repair_tool_call(original_call: string, error: string, tool_schema: string) {
    model: SmallCoder
    template: "extension_point:tmpl_repair_tool"
    returns: string
    timeout: 10s
    validate: schema_only
    on_invalid: fail
    retry: { max_attempts: 1, backoff: fixed, interval: 200ms }
  }

  // File summarization for large files
  prompt summarize_file(path: string, content: string, target_tokens: uint) {
    model: TinyRouter
    template: "extension_point:tmpl_summarize_file"
    returns: string
    timeout: 15s
    idempotent: true
    validate: schema_only
    cache: { key: hash(content), ttl: 1h }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // COGNITION CAPABILITIES — Bounded primitives
  // ═══════════════════════════════════════════════════════════════════════════

  // Bounded code retrieval: walk the symbol graph, cap at 8 files
  capability retrieve_context(t: Turn) {
    cognition: semantic_slice using {
      task: t.user_message,
      max_files: 8,
      hop_depth: 2
    }
    returns: CodeFile
    sync: eventual
    idempotent: true
  }

  // Compress context when budget is exceeded
  capability compress_context(s: Session, target_tokens: uint) {
    cognition: compress_context using {
      history: s.working_memory,
      target_tokens: target_tokens,
      strategy: "summarize_oldest"
    }
    returns: string
    sync: eventual
    idempotent: true
  }

  // Decompose a complex task into atomic steps
  capability plan_task(t: Turn) {
    cognition: decompose_task using {
      task: t.user_message,
      allowed_kinds: ["read_file", "edit_file", "create_file", "run_command", "search_code", "validate"],
      planner_prompt: "decompose_task"
    }
    returns: TaskPlan
    sync: eventual
  }

  // Self-critique a tool call result
  capability validate_edit(tc: ToolCall) {
    cognition: self_critique using {
      output: tc.result,
      criteria: ["compiles_without_errors", "matches_user_intent", "no_regressions"],
      validator_prompt: "repair_tool_call"
    }
    returns: string
    sync: eventual
  }

  // Repair a failed tool call
  capability repair_tool(tc: ToolCall) {
    cognition: repair_with_diff using {
      output: tc.result,
      error: tc.error,
      original_input: tc.arguments_json,
      repair_prompt: "repair_tool_call"
    }
    returns: string
    sync: eventual
  }

  // Tool capabilities (these are the tools the coding prompt can invoke)
  capability tool_read_file(path: string, start_line: uint, end_line: uint) {
    cognition: semantic_slice using {
      task: path,
      max_files: 1,
      hop_depth: 0
    }
    returns: string
    sync: eventual
    idempotent: true
  }

  capability tool_patch(path: string, old_str: string, new_str: string) {
    cognition: semantic_slice using {
      task: path,
      max_files: 1,
      hop_depth: 0
    }
    returns: string
    sync: transactional
  }

  capability tool_search(pattern: string, path: string) {
    cognition: semantic_slice using {
      task: pattern,
      max_files: 10,
      hop_depth: 1
    }
    returns: string
    sync: eventual
    idempotent: true
  }

  capability tool_bash(command: string) {
    cognition: semantic_slice using {
      task: command,
      max_files: 0,
      hop_depth: 0
    }
    returns: string
    sync: eventual
  }

  capability tool_memory(action: string, content: string) {
    cognition: semantic_slice using {
      task: action,
      max_files: 0,
      hop_depth: 0
    }
    returns: string
    sync: eventual
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // MAIN PIPELINE — The agent execution loop
  // ═══════════════════════════════════════════════════════════════════════════

  capability run_turn(s: Session, t: Turn) {
    pipeline: {
      classify_tool_category(t.user_message, s.working_memory) as category
      retrieve_context(t) as context
      match category {
        case "respond": coding_agent(t.user_message, s.working_memory, "", 0.1) as response
        case "plan": plan_task(t) as plan
        default: coding_agent(t.user_message, s.working_memory, category, 0.5) as response
      }
      on_error: rollback
    }
    sync: transactional
    timeout: 5m
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // FLOWS — Multi-step with checkpoints
  // ═══════════════════════════════════════════════════════════════════════════

  // For write operations, pause for user approval
  flow edit_with_approval {
    step generate: run_turn(s, t)
      checkpoint: approve_edit {
        shows: [t.user_message, t.assistant_response]
        allow: ["approve", "reject", "edit"]
        timeout: 5m
        on_timeout: cancel
      }
    step apply: validate_edit(tc)
      compensate: repair_tool(tc)
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // EVALUATIONS — Regression tests for prompts
  // ═══════════════════════════════════════════════════════════════════════════

  evaluation classify_accuracy {
    prompt: classify_tool_category

    cases: [
      {
        name: "read_request"
        input: { user_message: "show me the contents of main.ms", context_summary: "" }
        expected: {
          must_contain_string: ["read"]
        }
      },
      {
        name: "edit_request"
        input: { user_message: "fix the bug on line 42", context_summary: "" }
        expected: {
          must_contain_string: ["write"]
        }
      },
      {
        name: "search_request"
        input: { user_message: "find all uses of parseJson", context_summary: "" }
        expected: {
          must_contain_string: ["search"]
        }
      },
      {
        name: "run_request"
        input: { user_message: "run the tests", context_summary: "" }
        expected: {
          must_contain_string: ["run"]
        }
      },
      {
        name: "plan_request"
        input: { user_message: "implement a full authentication system with JWT", context_summary: "" }
        expected: {
          must_contain_string: ["plan"]
        }
      }
    ]

    metric: pass_rate
    baseline: { min_pass_rate: 0.80 }
    schedule: { on: ["pre_commit"] }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // EVENTS
  // ═══════════════════════════════════════════════════════════════════════════

  event TurnCompleted {
    payload: { session_id: uuid, turn_id: uuid, tokens_used: uint, tool_calls: uint }
    delivery: at_least_once
    ttl: 7d
  }

  event ToolCallFailed {
    payload: { turn_id: uuid, tool_name: string, error: string, attempt: uint }
    delivery: at_least_once
    ttl: 7d
  }

  event BudgetExhausted {
    payload: { session_id: uuid, tokens_used: uint, budget: uint }
    delivery: at_least_once
    ttl: 7d
  }

  event PlanCreated {
    payload: { session_id: uuid, plan_id: uuid, steps: uint }
    delivery: at_least_once
    ttl: 7d
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // POLICY — Rate limiting and cost budgets for local models
  // ═══════════════════════════════════════════════════════════════════════════

  policy agent_limits {
    rate_limit: 60 per 1m
    audit: true
    cost_budgets: [
      {
        scope: per_user
        window: 1h
        cap_tokens: 500000
        on_exceeded: { action: error, code: "TOKEN_BUDGET_EXCEEDED" }
      },
      {
        scope: per_feature: "run_turn"
        window: 1m
        cap_calls: 30
        on_exceeded: { action: throttle, retry_after: 30s }
      }
    ]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // EXTENSION POINTS — Custom logic that survives recompilation
  // ═══════════════════════════════════════════════════════════════════════════

  extension_point tmpl_classify_category(user_message: string, context_summary: string) {
    returns: string
    stable: true
  }

  extension_point tmpl_coding_agent(task: string, context: string, tool_schemas: string, complexity: float) {
    returns: string
    stable: true
  }

  extension_point tmpl_decompose(task_description: string, codebase_summary: string, complexity: float) {
    returns: string
    stable: true
  }

  extension_point tmpl_compress(history: string, max_tokens: uint) {
    returns: string
    stable: true
  }

  extension_point tmpl_repair_tool(original_call: string, error: string, tool_schema: string) {
    returns: string
    stable: true
  }

  extension_point tmpl_summarize_file(path: string, content: string, target_tokens: uint) {
    returns: string
    stable: true
  }
}
