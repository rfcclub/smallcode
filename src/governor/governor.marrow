// SmallCode Cognitive Governor (inspired by ARK)
// MarrowScript system declaration for:
// - Output verification with calibrated confidence
// - Hard fail enforcement (never deliver broken code)
// - Tool scoring with Bayesian learning
// - Auto-generated smoke tests
// - Per-step model routing that learns from failures

system SmallCodeGovernor {
  domain: cognitive_scaffold

  // ═══════════════════════════════════════════════════════════════════════════
  // ENTITIES — Governor State
  // ═══════════════════════════════════════════════════════════════════════════

  entity ToolScore {
    owns: [
      tool_name: string,
      task_type: string,
      success_count: uint,
      failure_count: uint,
      total_calls: uint,
      avg_latency_ms: uint,
      confidence: float,
      last_used: timestamp
    ]
    constraints: [
      confidence >= 0.0,
      confidence <= 1.0,
      total_calls == success_count + failure_count
    ]
  }

  entity VerificationResult {
    owns: [
      step_id: uuid,
      confidence: float,
      grounded: bool,
      compiled: bool,
      executed: bool,
      tests_passed: bool,
      lint_clean: bool,
      auto_fixed: bool
    ]
    constraints: [confidence >= 0.0, confidence <= 1.0]
    states: pending -> verified -> failed | hard_fail
  }

  entity TaskClassification {
    owns: [
      task_text: string,
      task_type: string,
      predicted_steps: uint,
      predicted_tool_count: uint,
      requires_verification: bool,
      requires_strong_model: bool
    ]
    constraints: [predicted_steps >= 1, predicted_steps <= 20]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // MODELS — Governor uses the tiny model for classification
  // ═══════════════════════════════════════════════════════════════════════════

  model TinyClassifier {
    provider: ollama
    name: "qwen2.5-coder:1.5b"
    context_window: 8192
    max_output: 128
    temperature: 0.0
    cost_class: tiny
    latency_class: fast
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // PROMPTS — Governor prompts (cheap, fast, deterministic)
  // ═══════════════════════════════════════════════════════════════════════════

  // Classify task type (determines routing + verification strategy)
  prompt classify_task_type(task: string) {
    model: TinyClassifier
    template: "extension_point:tmpl_classify_task_type"
    returns: string
    timeout: 3s
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 100ms }
    cache: { key: hash(task), ttl: 10m }
    constraints: [
      output in ["coding", "editing", "search", "shell", "explanation", "multi_step", "debugging", "backend"]
    ]
  }

  // Generate smoke test for code verification
  prompt generate_smoke_test(code: string, language: string, filename: string) {
    model: TinyClassifier
    template: "extension_point:tmpl_generate_test"
    returns: string
    timeout: 10s
    validate: schema_only
    on_invalid: fail
    retry: { max_attempts: 1, backoff: fixed, interval: 200ms }
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // COGNITION — Governor primitives
  // ═══════════════════════════════════════════════════════════════════════════

  // Self-critique: verify output quality
  capability verify_output(vr: VerificationResult) {
    cognition: self_critique using {
      output: vr,
      criteria: ["compiles_without_errors", "no_placeholders", "no_truncation", "matches_intent"],
      validator_prompt: "classify_task_type"
    }
    returns: VerificationResult
    sync: eventual
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // POLICY — Hard fail, cost budgets
  // ═══════════════════════════════════════════════════════════════════════════

  policy governor_policy {
    rate_limit: 120 per 1m
    audit: true
    cost_budgets: [
      {
        scope: per_feature: "verify_output"
        window: 1h
        cap_calls: 200
        on_exceeded: { action: throttle, retry_after: 30s }
      }
    ]
  }

  // ═══════════════════════════════════════════════════════════════════════════
  // EXTENSION POINTS
  // ═══════════════════════════════════════════════════════════════════════════

  extension_point tmpl_classify_task_type(task: string) {
    returns: string
    stable: true
  }

  extension_point tmpl_generate_test(code: string, language: string, filename: string) {
    returns: string
    stable: true
  }
}
