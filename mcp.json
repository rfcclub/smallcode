{
  "mcpServers": {
    "smallcode": {
      "command": "smallcode",
      "args": ["--mcp"],
      "env": {
        "OLLAMA_HOST": "http://localhost:11434"
      },
      "disabled": false,
      "autoApprove": [
        "smallcode_read_file",
        "smallcode_search",
        "smallcode_find_files",
        "smallcode_symbols",
        "smallcode_memory"
      ]
    }
  }
}
