// SmallCode Core — Focused agent system for compilation
// Stripped to essential declarations to compile cleanly

system SmallCodeCore {
  domain: cognitive_scaffold

  entity Session {
    owns: [
      model_name: string,
      provider: string,
      context_budget: uint,
      turn_count: uint,
      working_memory: string
    ]
    constraints: [context_budget > 0, turn_count >= 0]
    states: active -> completed | abandoned
  }

  entity Turn {
    owns: [
      session_id: uuid,
      user_message: string,
      assistant_response: string,
      tool_calls: uint,
      tokens_used: uint
    ]
    constraints: [tool_calls >= 0, tokens_used >= 0]
    states: pending -> responding -> complete | failed
  }

  model TinyClassifier {
    provider: ollama
    name: "qwen2.5-coder:1.5b"
    context_window: 8192
    max_output: 128
    temperature: 0.0
    cost_class: tiny
    latency_class: fast
  }

  model SmallCoder {
    provider: ollama
    name: "qwen2.5-coder:7b"
    context_window: 32000
    max_output: 4096
    temperature: 0.1
    cost_class: small
    latency_class: medium
  }

  model MediumCoder {
    provider: ollama
    name: "qwen2.5-coder:14b"
    context_window: 32000
    max_output: 8192
    temperature: 0.1
    cost_class: medium
    latency_class: medium
  }

  router coding_router {
    by: input.complexity
    tier trivial { max: 0.3 -> TinyClassifier }
    tier simple  { max: 0.6 -> SmallCoder }
    tier complex {           -> MediumCoder }
    on_low_confidence: escalate
    confidence_threshold: 0.6
    fallback: MediumCoder
  }

  prompt classify_category(user_message: string) {
    model: TinyClassifier
    template: "extension_point:tmpl_classify"
    returns: string
    timeout: 5s
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 200ms }
    cache: { key: hash(user_message), ttl: 5m }
  }

  prompt code_assist(task: string, context: string, complexity: float) {
    router: coding_router
    template: "extension_point:tmpl_code_assist"
    returns: string
    timeout: 120s
    validate: schema_only
    on_invalid: retry_with_repair_prompt
    retry: { max_attempts: 3, backoff: exponential, interval: 1s }
    stream: true
  }

  prompt compress_history(history: string, max_tokens: uint) {
    model: SmallCoder
    template: "extension_point:tmpl_compress"
    returns: string
    timeout: 30s
    idempotent: true
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 500ms }
  }

  prompt decompose(task: string, complexity: float) {
    router: coding_router
    template: "extension_point:tmpl_decompose"
    returns: string
    timeout: 30s
    validate: schema_only
    on_invalid: retry
    retry: { max_attempts: 2, backoff: fixed, interval: 500ms }
  }

  capability slice_context(t: Turn) {
    cognition: semantic_slice using {
      task: t.user_message,
      max_files: 8,
      hop_depth: 2
    }
    returns: string
    sync: eventual
    idempotent: true
  }

  capability compress_ctx(s: Session, target: uint) {
    cognition: compress_context using {
      history: s.working_memory,
      target_tokens: target,
      strategy: "summarize_oldest"
    }
    returns: string
    sync: eventual
    idempotent: true
  }

  capability plan_steps(t: Turn) {
    cognition: decompose_task using {
      task: t.user_message,
      allowed_kinds: ["read_file", "edit_file", "create_file", "run_command", "search_code", "validate"],
      planner_prompt: "decompose"
    }
    returns: string
    sync: eventual
  }

  event TurnCompleted {
    payload: { session_id: uuid, turn_id: uuid, tokens_used: uint }
    delivery: at_least_once
    ttl: 7d
  }

  policy agent_limits {
    rate_limit: 60 per 1m
    audit: true
    cost_budgets: [
      {
        scope: per_user
        window: 1h
        cap_tokens: 500000
        on_exceeded: { action: error, code: "TOKEN_LIMIT" }
      }
    ]
  }

  extension_point tmpl_classify(user_message: string) {
    returns: string
    stable: true
  }

  extension_point tmpl_code_assist(task: string, context: string, complexity: float) {
    returns: string
    stable: true
  }

  extension_point tmpl_compress(history: string, max_tokens: uint) {
    returns: string
    stable: true
  }

  extension_point tmpl_decompose(task: string, complexity: float) {
    returns: string
    stable: true
  }
}
