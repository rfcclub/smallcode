{
  "name": "smallcode",
  "version": "1.2.3",
  "description": "AI coding agent optimized for small LLMs (8B-35B parameters)",
  "main": "src/api/index.js",
  "bin": {
    "smallcode": "bin/smallcode.js",
    "smallcode-init": "bin/init.js"
  },
  "scripts": {
    "build": "node build.js",
    "start": "node bin/smallcode.js",
    "dev": "node bin/smallcode.js",
    "eval": "node bin/smallcode.js --eval classify_accuracy",
    "mcp": "node bin/smallcode.js --mcp",
    "bench": "node bench/harness.js --suite smoke",
    "bench:smoke": "node bench/harness.js --suite smoke",
    "bench:polyglot": "node bench/harness.js --suite polyglot-mini",
    "bench:tools": "node bench/harness.js --suite tool-use",
    "bench:list": "node bench/harness.js --list",
    "bench:diff": "node bench/diff.js",
    "test": "node --test test/*.test.js",
    "test:e2e": "node test/e2e_smoke.js"
  },
  "dependencies": {
    "bonescript-compiler": "0.14.0",
    "chalk": "4.1.2",
    "cli-highlight": "2.1.11",
    "express": "^5.2.1",
    "marked": "15.0.12",
    "marked-terminal": "7.3.0"
  },
  "optionalDependencies": {
    "budget-aware-mcp": "0.6.1"
  },
  "peerDependencies": {
    "playwright-extra": "^4.3.0",
    "puppeteer-extra-plugin-stealth": "^2.11.0"
  },
  "peerDependenciesMeta": {
    "playwright-extra": { "optional": true },
    "puppeteer-extra-plugin-stealth": { "optional": true }
  },
  "keywords": [
    "ai",
    "coding-agent",
    "llm",
    "ollama",
    "terminal",
    "small-models",
    "marrowscript",
    "mcp"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "glob": "13.0.6",
    "rimraf": "6.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "jest": "^30.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
